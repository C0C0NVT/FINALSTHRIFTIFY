<Window x:Class="FINALSTHRIFTIFY.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thriftify - Sign Up" 
        Height="746" Width="344"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#5F9F7B">
    <Window.Resources>
        <!-- Color Resources -->
        <SolidColorBrush x:Key="BackgroundColor" Color="#5F9F7B"/>
        <SolidColorBrush x:Key="WhiteColor" Color="White"/>
        <SolidColorBrush x:Key="LinkColor" Color="#193B2B"/>
        <SolidColorBrush x:Key="PlaceholderColor" Color="#AAAAAA"/>

        <!-- Button Gradient -->
        <LinearGradientBrush x:Key="ButtonGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#45A176" Offset="0"/>
            <GradientStop Color="#193B2B" Offset="1"/>
        </LinearGradientBrush>

        <!-- Styles -->
        <Style x:Key="LogoStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StyledButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonGradient}"/>
            <Setter Property="Foreground" Value="{StaticResource WhiteColor}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="20" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-2"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,10,35,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="20" 
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundColor}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="50,20,50,20">
                <TextBlock Text="Thriftify" Style="{StaticResource LogoStyle}" 
                          HorizontalAlignment="Left" Margin="0,0,0,20"/>
                <TextBlock Text="Create Account" FontFamily="Segoe UI" FontSize="20" 
                          Foreground="White" HorizontalAlignment="Left" Margin="0,0,0,4"/>
                <TextBlock Text="Join Thriftify and start managing your finances" FontFamily="Segoe UI" FontSize="13" 
                          Foreground="White" HorizontalAlignment="Left" Margin="0,0,0,20"/>

                <!-- Username Input -->
                <Grid Margin="0,0,0,15" Width="250" HorizontalAlignment="Left">
                    <TextBox x:Name="UsernameTextBox" Style="{StaticResource RoundedTextBox}" 
                             GotFocus="UsernameTextBox_GotFocus" LostFocus="UsernameTextBox_LostFocus"/>
                    <TextBlock x:Name="UsernamePlaceholder" Text="Username" 
                              FontFamily="Segoe UI" FontSize="13" 
                              Foreground="{StaticResource PlaceholderColor}"
                              IsHitTestVisible="False" 
                              Margin="15,10,0,0"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Margin="0,0,10,0" Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource PlaceholderColor}" FontSize="12"
                            Click="ClearUsername_Click" Cursor="Hand"/>
                </Grid>

                <!-- Display Name Input -->
                <Grid Margin="0,0,0,15" Width="250" HorizontalAlignment="Left">
                    <TextBox x:Name="DisplayNameTextBox" Style="{StaticResource RoundedTextBox}" 
                             GotFocus="DisplayNameTextBox_GotFocus" LostFocus="DisplayNameTextBox_LostFocus"/>
                    <TextBlock x:Name="DisplayNamePlaceholder" Text="Full Name" 
                              FontFamily="Segoe UI" FontSize="13" 
                              Foreground="{StaticResource PlaceholderColor}"
                              IsHitTestVisible="False" 
                              Margin="15,10,0,0"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Margin="0,0,10,0" Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource PlaceholderColor}" FontSize="12"
                            Click="ClearDisplayName_Click" Cursor="Hand"/>
                </Grid>

                <!-- Email Input -->
                <Grid Margin="0,0,0,15" Width="250" HorizontalAlignment="Left">
                    <TextBox x:Name="EmailTextBox" Style="{StaticResource RoundedTextBox}" 
                             GotFocus="EmailTextBox_GotFocus" LostFocus="EmailTextBox_LostFocus"/>
                    <TextBlock x:Name="EmailPlaceholder" Text="Email Address" 
                              FontFamily="Segoe UI" FontSize="13" 
                              Foreground="{StaticResource PlaceholderColor}"
                              IsHitTestVisible="False" 
                              Margin="15,10,0,0"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Margin="0,0,10,0" Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource PlaceholderColor}" FontSize="12"
                            Click="ClearEmail_Click" Cursor="Hand"/>
                </Grid>

                <!-- Password Input -->
                <Grid Margin="0,0,0,15" Width="250" HorizontalAlignment="Left">
                    <PasswordBox x:Name="PasswordBox" FontFamily="Segoe UI" FontSize="13" 
                                Padding="15,10,35,10" BorderThickness="0" Background="White"
                                GotFocus="PasswordBox_GotFocus" LostFocus="PasswordBox_LostFocus">
                        <PasswordBox.Template>
                            <ControlTemplate TargetType="PasswordBox">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="20" 
                                        Padding="{TemplateBinding Padding}">
                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                </Border>
                            </ControlTemplate>
                        </PasswordBox.Template>
                    </PasswordBox>
                    <TextBlock x:Name="PasswordPlaceholder" Text="Password" 
                              FontFamily="Segoe UI" FontSize="13" 
                              Foreground="{StaticResource PlaceholderColor}"
                              IsHitTestVisible="False" 
                              Margin="15,10,0,0"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Margin="0,0,10,0" Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource PlaceholderColor}" FontSize="12"
                            Click="ClearPassword_Click" Cursor="Hand"/>
                </Grid>

                <!-- Confirm Password Input -->
                <Grid Margin="0,0,0,15" Width="250" HorizontalAlignment="Left">
                    <PasswordBox x:Name="ConfirmPasswordBox" FontFamily="Segoe UI" FontSize="13" 
                                Padding="15,10,35,10" BorderThickness="0" Background="White"
                                GotFocus="ConfirmPasswordBox_GotFocus" LostFocus="ConfirmPasswordBox_LostFocus">
                        <PasswordBox.Template>
                            <ControlTemplate TargetType="PasswordBox">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="20" 
                                        Padding="{TemplateBinding Padding}">
                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                </Border>
                            </ControlTemplate>
                        </PasswordBox.Template>
                    </PasswordBox>
                    <TextBlock x:Name="ConfirmPasswordPlaceholder" Text="Confirm Password" 
                              FontFamily="Segoe UI" FontSize="13" 
                              Foreground="{StaticResource PlaceholderColor}"
                              IsHitTestVisible="False" 
                              Margin="15,10,0,0"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Margin="0,0,10,0" Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource PlaceholderColor}" FontSize="12"
                            Click="ClearConfirmPassword_Click" Cursor="Hand"/>
                </Grid>

                <!-- Terms and Conditions -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <CheckBox x:Name="TermsCheckBox" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock FontFamily="Segoe UI" FontSize="13" Foreground="White" TextWrapping="Wrap">
                        <Run Text="I agree to the "/>
                        <Run Text="Terms of Service" Foreground="{StaticResource LinkColor}" 
                             TextDecorations="Underline" Cursor="Hand" MouseLeftButtonUp="Terms_Click"/>
                        <Run Text=" and "/>
                        <Run Text="Privacy Policy" Foreground="{StaticResource LinkColor}" 
                             TextDecorations="Underline" Cursor="Hand" MouseLeftButtonUp="Privacy_Click"/>
                    </TextBlock>
                </StackPanel>

                <!-- Sign Up Button -->
                <Button Content="CREATE ACCOUNT" Style="{StaticResource StyledButton}" 
                        Width="250" Height="40" Click="SignUpSubmit_Click" 
                        HorizontalAlignment="Left" Margin="0,0,0,16"/>

                <!-- Sign In Link -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="Already have an account? " FontFamily="Segoe UI" FontSize="13" 
                              Foreground="White"/>
                    <TextBlock Text="Sign in" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                              Foreground="{StaticResource LinkColor}" Cursor="Hand" 
                              TextDecorations="Underline" MouseLeftButtonUp="SignIn_Click"/>
                </StackPanel>

                <TextBlock x:Name="ErrorTextBlock" 
                           Foreground="#FF6B6B" 
                           TextWrapping="Wrap"
                           Margin="0,15,0,0"
                           FontSize="12"
                           HorizontalAlignment="Left"
                           Visibility="Collapsed"/>

                <TextBlock x:Name="SuccessTextBlock" 
                           Foreground="#8FD398" 
                           TextWrapping="Wrap"
                           Margin="0,15,0,0"
                           FontSize="12"
                           HorizontalAlignment="Left"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>