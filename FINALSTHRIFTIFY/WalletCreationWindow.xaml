<Window x:Class="FINALSTHRIFTIFY.WalletCreationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thriftify - Wallet Management" 
        Height="746" Width="344"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#5F9F7B">
    <Window.Resources>
        <!-- Color Resources -->
        <SolidColorBrush x:Key="BackgroundColor" Color="#5F9F7B"/>
        <SolidColorBrush x:Key="WhiteColor" Color="White"/>
        <SolidColorBrush x:Key="CardBackground" Color="#F5F5F5"/>

        <!-- Button Gradient -->
        <LinearGradientBrush x:Key="ButtonGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#45A176" Offset="0"/>
            <GradientStop Color="#193B2B" Offset="1"/>
        </LinearGradientBrush>

        <!-- Styles -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="20" 
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WalletTypeButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15" 
                                Padding="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#45A176"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundColor}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- Header -->
                <Grid Margin="0,0,0,20">
                    <Button x:Name="BackButton" Content="←" Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="24" FontWeight="Bold" Width="40" Height="40"
                            HorizontalAlignment="Left" Click="BackButton_Click" Cursor="Hand"/>
                    <TextBlock x:Name="HeaderText" Text="Add Wallet" FontSize="20" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- Choose Template Section -->
                <TextBlock Text="Choose Template" FontWeight="Bold" FontSize="16" 
                           Foreground="White" Margin="0,0,0,10"/>

                <!-- Wallet Type Carousel -->
                <Grid Height="120" Margin="0,0,0,20">
                    <ScrollViewer x:Name="WalletTypeScrollViewer" HorizontalScrollBarVisibility="Auto" 
                                  VerticalScrollBarVisibility="Hidden">
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <Button x:Name="CashWalletButton" Style="{StaticResource WalletTypeButton}" 
                                    Width="100" Height="100" Click="WalletType_Click" Tag="Cash" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="💵" FontSize="30" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="Cash" FontSize="12" FontWeight="Bold" 
                                               Foreground="#45A176" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="GCashWalletButton" Style="{StaticResource WalletTypeButton}" 
                                    Width="100" Height="100" Click="WalletType_Click" Tag="GCash" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="📱" FontSize="30" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="GCash" FontSize="12" FontWeight="Bold" 
                                               Foreground="#3B79BF" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="MayaWalletButton" Style="{StaticResource WalletTypeButton}" 
                                    Width="100" Height="100" Click="WalletType_Click" Tag="Maya" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="🏦" FontSize="30" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="Maya" FontSize="12" FontWeight="Bold" 
                                               Foreground="#FF6B35" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BankWalletButton" Style="{StaticResource WalletTypeButton}" 
                                    Width="100" Height="100" Click="WalletType_Click" Tag="Bank" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="🏛️" FontSize="30" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="Bank" FontSize="12" FontWeight="Bold" 
                                               Foreground="#1E3A8A" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="CustomWalletButton" Style="{StaticResource WalletTypeButton}" 
                                    Width="100" Height="100" Click="WalletType_Click" Tag="Custom" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="➕" FontSize="30" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                    <TextBlock Text="Custom" FontSize="12" FontWeight="Bold" 
                                               Foreground="#8FD398" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Wallet Name -->
                <TextBlock Text="Wallet Name" FontWeight="Bold" FontSize="16" 
                           Foreground="White" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <TextBox x:Name="WalletNameTextBox" Style="{StaticResource RoundedTextBox}" 
                             Height="40" VerticalContentAlignment="Center"
                             GotFocus="WalletNameTextBox_GotFocus" LostFocus="WalletNameTextBox_LostFocus"/>
                    <TextBlock x:Name="WalletNamePlaceholder" Text="Enter wallet name" 
                               FontSize="13" Foreground="#AAAAAA" IsHitTestVisible="False" 
                               Margin="15,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <!-- Initial Balance -->
                <TextBlock Text="Initial Balance" FontWeight="Bold" FontSize="16" 
                           Foreground="White" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <TextBox x:Name="InitialBalanceTextBox" Style="{StaticResource RoundedTextBox}" 
                             Height="40" VerticalContentAlignment="Center"
                             GotFocus="InitialBalanceTextBox_GotFocus" LostFocus="InitialBalanceTextBox_LostFocus"/>
                    <TextBlock x:Name="InitialBalancePlaceholder" Text="0.00" 
                               FontSize="13" Foreground="#AAAAAA" IsHitTestVisible="False" 
                               Margin="15,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <!-- Select Background Color -->
                <TextBlock Text="Select Background Color" FontWeight="Bold" FontSize="16" 
                           Foreground="White" Margin="0,0,0,10"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden" Height="60" Margin="0,0,0,15">
                    <StackPanel x:Name="BackgroundColorPanel" Orientation="Horizontal">
                        <!-- Colors will be added programmatically -->
                    </StackPanel>
                </ScrollViewer>

                <!-- Select Text Color -->
                <TextBlock Text="Select Text Color" FontWeight="Bold" FontSize="16" 
                           Foreground="White" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button x:Name="BlackTextButton" Style="{StaticResource ColorButton}" 
                            Background="Black" Click="TextColor_Click" Tag="Black"/>
                    <Button x:Name="WhiteTextButton" Style="{StaticResource ColorButton}" 
                            Background="White" Click="TextColor_Click" Tag="White"/>
                    <Button x:Name="DarkGreenTextButton" Style="{StaticResource ColorButton}" 
                            Background="#2C5F3E" Click="TextColor_Click" Tag="DarkGreen"/>
                </StackPanel>

                <!-- Preview -->
                <TextBlock Text="Preview" FontWeight="Bold" FontSize="16" 
                           Foreground="White" Margin="0,0,0,10"/>
                <Border x:Name="PreviewBorder" Background="#8FD398" CornerRadius="15" Padding="15" 
                        Height="100" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock x:Name="PreviewWalletName" Text="My Wallet" FontWeight="Bold" FontSize="16"
                                   Foreground="Black"/>
                        <TextBlock x:Name="PreviewWalletType" Text="Cash" FontSize="12" Opacity="0.8"
                                   Foreground="Black" Margin="0,2,0,8"/>
                        <TextBlock Text="Balance" FontSize="11" Opacity="0.7" Foreground="Black"/>
                        <TextBlock x:Name="PreviewBalance" Text="₱0.00" FontSize="20" FontWeight="Bold"
                                   Foreground="Black"/>
                    </StackPanel>
                </Border>

                <!-- Save Button -->
                <Button x:Name="SaveButton" Content="SAVE WALLET" Style="{StaticResource ModernButtonStyle}"
                        Height="50" Click="SaveButton_Click"/>

                <!-- Delete Button (only shown when editing) -->
                <Button x:Name="DeleteButton" Content="DELETE WALLET" Background="#D84F4E" 
                        Foreground="White" FontWeight="Bold" Height="50" Margin="0,10,0,0"
                        Click="DeleteButton_Click" Visibility="Collapsed"
                        Style="{StaticResource ModernButtonStyle}"/>

                <!-- Error/Success Messages -->
                <TextBlock x:Name="ErrorTextBlock" Foreground="#FF6B6B" TextWrapping="Wrap"
                           Margin="0,15,0,0" FontSize="12" HorizontalAlignment="Center"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="SuccessTextBlock" Foreground="#8FD398" TextWrapping="Wrap"
                           Margin="0,15,0,0" FontSize="12" HorizontalAlignment="Center"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>