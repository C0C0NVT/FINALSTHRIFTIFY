<Window x:Class="FINALSTHRIFTIFY.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thriftify - Admin Dashboard" 
        Height="746" Width="344"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#5F9F7B">
    <Window.Resources>
        <Style x:Key="RoundButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#8FD398"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="25">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#69886D" Padding="15">
            <StackPanel>
                <TextBlock x:Name="WelcomeText" 
                           Text="Welcome, Admin" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Background="#F5F5F5" BorderThickness="0">
            <TabItem Header="User Management">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="User Accounts" FontWeight="Bold" Margin="0,0,0,10"/>

                        <ListView x:Name="UsersListView" Height="250" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding username}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding user_type}"/>
                                        <TextBlock Text="{Binding email}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Button Content="Disable" Click="DisableUser_Click" Tag="{Binding user_id}" 
                                                    Margin="0,0,5,0" Background="#D84F4E" Foreground="White" 
                                                    Style="{StaticResource RoundButtonStyle}"/>
                                            <Button Content="Enable" Click="EnableUser_Click" Tag="{Binding user_id}" 
                                                    Margin="0,0,5,0" Background="#8FD398" Foreground="White" 
                                                    Style="{StaticResource RoundButtonStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="System Data">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="Categories" FontWeight="Bold" Margin="0,0,0,10"/>

                        <ListView x:Name="CategoriesListView" Height="150" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding category_name}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding category_type}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                            <TextBox x:Name="NewCategoryName" Width="120" Margin="0,0,5,0" 
                                     Height="35"/>
                            <ComboBox x:Name="NewCategoryType" Width="100" Margin="0,0,5,0">
                                <ComboBoxItem Content="Income"/>
                                <ComboBoxItem Content="Expense"/>
                            </ComboBox>
                            <Button Content="Add" Click="AddCategory_Click" 
                                    Style="{StaticResource RoundButtonStyle}" Width="60"/>
                        </StackPanel>

                        <TextBlock x:Name="CategoryErrorText" Foreground="#9F0909" Margin="0,5,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#69886D">
            <Grid>
                <Button Content="LOGOUT" Click="Logout_Click" 
                        Style="{StaticResource NavButtonStyle}" 
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        FontSize="16"/>
            </Grid>
        </Border>
    </Grid>
</Window>