<Window x:Class="FINALSTHRIFTIFY.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thriftify - Admin Dashboard" 
        Height="746" Width="344"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#5F9F7B">
    <Window.Resources>
        <Style x:Key="RoundButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#8FD398"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="25">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#69886D" Padding="15">
            <StackPanel>
                <TextBlock x:Name="WelcomeText" 
                           Text="Welcome, Admin" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Background="#F5F5F5" BorderThickness="0">
            <TabItem Header="User Management">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="User Accounts" FontWeight="Bold" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Show:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ComboBox x:Name="UserFilterComboBox" Width="120" SelectedIndex="0" 
                                          SelectionChanged="UserFilter_Changed">
                                    <ComboBoxItem Content="Active Users"/>
                                    <ComboBoxItem Content="All Users"/>
                                    <ComboBoxItem Content="Inactive Users"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <ItemsControl x:Name="UsersItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="10" Margin="0,5" Padding="15"
                                            BorderBrush="#E0E0E0" BorderThickness="1">
                                        <Grid>
                                            <StackPanel>
                                                <Grid>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding display_name}" FontWeight="Bold" FontSize="16"/>
                                                        <TextBlock Text="{Binding username}" FontSize="12" Foreground="#666" Margin="0,2,0,0"/>
                                                        <TextBlock Text="{Binding email}" FontSize="12" Foreground="#666"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                            <Border Background="{Binding StatusColor}" CornerRadius="10" Padding="5,2">
                                                                <TextBlock Text="{Binding StatusText}" FontSize="10" 
                                                                           Foreground="White" FontWeight="Bold"/>
                                                            </Border>
                                                            <Border Background="#45A176" CornerRadius="10" Padding="5,2" Margin="5,0,0,0">
                                                                <TextBlock Text="{Binding user_type}" FontSize="10" 
                                                                           Foreground="White" FontWeight="Bold"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding created_at, StringFormat=MMM dd, yyyy}" 
                                                               FontSize="10" Foreground="#999" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                                </Grid>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                                <Button Content="👁️" Background="Transparent" BorderThickness="0"
                                                        Foreground="#45A176" FontSize="14" Width="30" Height="30"
                                                        Click="ViewUser_Click" Tag="{Binding user_id}" ToolTip="View Details"/>
                                                <Button Background="Transparent" BorderThickness="0" FontSize="12" Width="60" Height="25"
                                                        Click="ToggleUser_Click" Tag="{Binding user_id}" ToolTip="Enable/Disable User">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding is_active}" Value="True">
                                                                    <Setter Property="Content" Value="Disable"/>
                                                                    <Setter Property="Foreground" Value="#D84F4E"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding is_active}" Value="False">
                                                                    <Setter Property="Content" Value="Enable"/>
                                                                    <Setter Property="Foreground" Value="#8FD398"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="🗑️" Background="Transparent" BorderThickness="0"
                                                        Foreground="#FF6B6B" FontSize="12" Width="25" Height="25"
                                                        Click="DeleteUser_Click" Tag="{Binding user_id}" ToolTip="Delete User"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="System Data">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="Categories" FontWeight="Bold" Margin="0,0,0,10"/>

                        <ListView x:Name="CategoriesListView" Height="150" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding category_name}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding category_type}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                            <TextBox x:Name="NewCategoryName" Width="120" Margin="0,0,5,0" 
                                     Height="35"/>
                            <ComboBox x:Name="NewCategoryType" Width="100" Margin="0,0,5,0">
                                <ComboBoxItem Content="Income"/>
                                <ComboBoxItem Content="Expense"/>
                            </ComboBox>
                            <Button Content="Add" Click="AddCategory_Click" 
                                    Style="{StaticResource RoundButtonStyle}" Width="60"/>
                        </StackPanel>

                        <TextBlock x:Name="CategoryErrorText" Foreground="#9F0909" Margin="0,5,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#69886D">
            <Grid>
                <Button Content="LOGOUT" Click="Logout_Click" 
                        Style="{StaticResource NavButtonStyle}" 
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        FontSize="16"/>
            </Grid>
        </Border>
    </Grid>
</Window>