<Window x:Class="FINALSTHRIFTIFY.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FINALSTHRIFTIFY"
        Title="Thriftify - User Dashboard" 
        Height="746" Width="344"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#5F9F7B">
    <Window.Resources>
        <Style x:Key="RoundButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#8FD398"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="25">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <StackPanel>
                                <TextBlock Text="{TemplateBinding Tag}" FontSize="20" 
                                           HorizontalAlignment="Center" Margin="0,0,0,3"
                                           Foreground="{TemplateBinding Foreground}"/>
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#557A5F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActiveNavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#557A5F"/>
        </Style>

        <Style x:Key="MenuItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Tag}" FontSize="16" 
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WalletButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#45A176"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExpenseButtonStyle" TargetType="Button" BasedOn="{StaticResource WalletButtonStyle}">
            <Setter Property="Background" Value="#D84F4E"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#69886D" Padding="15">
            <StackPanel>
                <TextBlock x:Name="WelcomeText" 
                           Text="Welcome, User" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <TabControl x:Name="MainTabControl" Grid.Row="1" Background="#F5F5F5" BorderThickness="0">
            <TabItem x:Name="OverviewTab" Header="Overview">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <Border Background="#E8F5E9" CornerRadius="10" Padding="10" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Currency Converter" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBox x:Name="AmountToConvert" Text="0" Margin="0,0,0,10"/>
                                <ComboBox x:Name="CurrencySelector" Margin="0,0,0,10">
                                    <ComboBoxItem Content="USD - US Dollar" Tag="56.50"/>
                                    <ComboBoxItem Content="JPY - Japanese Yen" Tag="0.38"/>
                                    <ComboBoxItem Content="KRW - South Korean Won" Tag="0.042"/>
                                    <ComboBoxItem Content="EUR - Euro" Tag="60.25"/>
                                </ComboBox>
                                <Button Content="Convert" Click="ConvertCurrency_Click"
                                        Style="{StaticResource RoundButtonStyle}" Margin="0,0,0,10"/>
                                <TextBlock x:Name="ConversionResult" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Your Wallets" FontWeight="Bold" Margin="0,0,0,10"/>

                        <ListView x:Name="WalletsListView" Height="150" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding BgColor}" CornerRadius="10" Padding="10" 
                                            BorderThickness="5,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding wallet_name}" FontWeight="Bold" Foreground="Green"/>
                                            <TextBlock Text="Balance" FontSize="11" Foreground="Green" Opacity="0.8"/>
                                            <TextBlock Text="{Binding current_balance, StringFormat={}{0:C}}" 
                                                       FontSize="18" FontWeight="Bold" Foreground="Green"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <Button Content="Add Funds" Tag="{Binding wallet_id}" 
                                                        Style="{StaticResource WalletButtonStyle}" 
                                                        Margin="0,0,5,0"/>
                                                <Button Content="Spend" Tag="{Binding wallet_id}" 
                                                        Style="{StaticResource ExpenseButtonStyle}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Button Content="Add Wallet" Click="AddWallet_Click" 
                                Style="{StaticResource RoundButtonStyle}" Margin="0,10,0,10"/>

                        <TextBlock Text="Recent Transactions" FontWeight="Bold" Margin="0,20,0,10"/>

                        <ListView x:Name="TransactionsListView" Height="200" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock>
                                            <Run Text="{Binding transaction_type}" FontWeight="Bold"/>
                                            <Run Text=" - "/>
                                            <Run Text="{Binding description}" FontStyle="Italic"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="{Binding transaction_date, StringFormat={}{0:MMM dd}}"/>
                                            <Run Text=" - "/>
                                            <Run Text="{Binding amount, StringFormat={}{0:C}}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="HistoryTab" Header="History">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="Transaction History" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                        <ListView x:Name="AllTransactionsListView" Height="400" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="8" Padding="10" Margin="0,2">
                                        <StackPanel>
                                            <TextBlock>
                                                <Run Text="{Binding transaction_type}" FontWeight="Bold"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding description}" FontStyle="Italic"/>
                                            </TextBlock>
                                            <TextBlock>
                                                <Run Text="{Binding transaction_date, StringFormat={}{0:MMM dd, yyyy}}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding amount, StringFormat={}{0:C}}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="AddTransactionTab" Header="Add Transaction">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="Add New Transaction" FontWeight="Bold" Margin="0,0,0,10"/>

                        <ComboBox x:Name="WalletComboBox" DisplayMemberPath="wallet_name" Margin="0,0,0,10"/>

                        <ComboBox x:Name="TransactionTypeComboBox" Margin="0,0,0,10">
                            <ComboBoxItem Content="Income"/>
                            <ComboBoxItem Content="Expense"/>
                        </ComboBox>

                        <ComboBox x:Name="CategoryComboBox" DisplayMemberPath="category_name" Margin="0,0,0,10"/>

                        <TextBox x:Name="AmountTextBox" Margin="0,0,0,10"/>

                        <TextBox x:Name="DescriptionTextBox" Margin="0,0,0,10"/>

                        <Button Content="Add Transaction" Click="AddTransaction_Click"
                                Style="{StaticResource RoundButtonStyle}"/>

                        <TextBlock x:Name="TransactionErrorText" Foreground="#9F0909" Margin="0,10,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="BalanceTab" Header="Balance">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="Wallet Balances" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                        <ListView x:Name="BalanceWalletsListView" Height="400" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="10" Padding="15" Margin="0,5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding wallet_name}" FontWeight="Bold" FontSize="16" Foreground="Green"/>
                                            <TextBlock Text="Current Balance" FontSize="12" Foreground="Green" Opacity="0.8" Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding current_balance, StringFormat={}{0:C}}" 
                                                       FontSize="24" FontWeight="Bold" Foreground="Green"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#69886D">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="HomeButton" Grid.Column="0" Style="{StaticResource ActiveNavButtonStyle}" 
                        Tag="🏠" Content="Home" Click="NavButton_Click"/>
                <Button x:Name="HistoryButton" Grid.Column="1" Style="{StaticResource NavButtonStyle}" 
                        Tag="🕒" Content="History" Click="NavButton_Click"/>
                <Button x:Name="AddButton" Grid.Column="2" Style="{StaticResource NavButtonStyle}" 
                        Tag="➕" Content="Add" Click="NavButton_Click"/>
                <Button x:Name="BalanceButton" Grid.Column="3" Style="{StaticResource NavButtonStyle}" 
                        Tag="₱" Content="Balance" Click="NavButton_Click"/>
                <Button x:Name="SettingsButton" Grid.Column="4" Style="{StaticResource NavButtonStyle}" 
                        Tag="⚙️" Content="Settings" Click="SettingsButton_Click"/>
            </Grid>
        </Border>

        <!-- Settings Menu Overlay -->
        <Grid x:Name="SettingsOverlay" Grid.RowSpan="3" Background="#80000000" Visibility="Collapsed">
            <Border Background="White" CornerRadius="10" MaxWidth="280" MaxHeight="300" 
                    VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                <StackPanel>
                    <Border Background="#69886D" CornerRadius="10,10,0,0" Padding="15,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Settings" FontSize="16" FontWeight="Bold" 
                                       Foreground="White" VerticalAlignment="Center"/>
                            <Button Content="✕" Background="Transparent" BorderThickness="0" 
                                    Foreground="White" FontSize="16" FontWeight="Bold"
                                    HorizontalAlignment="Right" Margin="80,0,0,0"
                                    Click="CloseSettings_Click" Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                    
                    <StackPanel Margin="0,10,0,0">
                        <Button Style="{StaticResource MenuItemStyle}" Tag="🏥" Content="Help Center" 
                                Click="HelpCenter_Click"/>
                        <Separator Background="#E0E0E0" Height="1" Margin="15,0"/>
                        
                        <Button Style="{StaticResource MenuItemStyle}" Tag="⚠️" Content="Report a problem" 
                                Click="ReportProblem_Click"/>
                        <Separator Background="#E0E0E0" Height="1" Margin="15,0"/>
                        
                        <Button Style="{StaticResource MenuItemStyle}" Tag="📋" Content="Terms of Use" 
                                Click="TermsOfUse_Click"/>
                        <Separator Background="#E0E0E0" Height="1" Margin="15,0"/>
                        
                        <Button Style="{StaticResource MenuItemStyle}" Tag="⭐" Content="Rate the app" 
                                Click="RateApp_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>